# Odds / SBD configuration
ODDS_PROVIDER=sportsbettingdime
# Available books: draftkings, fanduel, betmgm, caesars, bet365, betrivers, pinnacle
ODDS_BOOKMAKERS=DraftKings,FanDuel,BetMGM,Caesars,Bet365,BetRivers,Pinnacle
# SBD Book IDs: DraftKings, FanDuel, BetMGM, Caesars, Bet365, BetRivers, Pinnacle
SBD_BOOK_IDS=sr:book:18149,sr:book:18186,sr:book:17324,sr:book:32219,sr:book:28901,sr:book:27447,sr:book:30334

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=YOUR_URL_HERE
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_KEY_HERE

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel CLI
VERCEL_TOKEN=YOUR_TOKEN_HERE

# OpenAI
OPENAI_API_KEY=YOUR_API_KEY_HERE

# Stripe API Keys
STRIPE_SECRET_KEY=

# Stripe Webhook Secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (create these in Stripe Dashboard → Products)
STRIPE_PRICE_PRO_TRIAL=prod_TfRI1UDCsvyQPi # Pro with 7-day trial
STRIPE_PRICE_PRO_MONTHLY=prod_TfRJmxR3optMWS # Pro monthly ($29)
STRIPE_PRICE_PRO_ANNUAL=prod_TfRLDmmKVy1bfN # Pro annual ($9/mo billed yearly)
STRIPE_PRICE_UNLIMITED_MONTHLY=prod_TfRKaR7g7mok7w # Unlimited monthly ($199)
STRIPE_PRICE_UNLIMITED_ANNUAL=prod_Tfn7AjFVBVSLdE # Unlimited annual ($83/mo billed yearly)
