{
  "name": "delta-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck",
    "test:custom-models": "ts-node --project tsconfig.test.json tests/custom-models.spec.ts",
    "test:odds": "ts-node --project tsconfig.test.json -r tsconfig-paths/register tests/odds-api.spec.ts",
    "test:ai-gateway": "npx tsx scripts/test-ai-gateway.ts",
    "compare:gpt5": "npx tsx scripts/compare-gpt5-models.ts",
    "cleanup:messages": "npx ts-node scripts/cleanup-null-messages.ts",
    "ingest:injuries": "ts-node --project tsconfig.scripts.json -r tsconfig-paths/register scripts/ingest-injuries.ts",
    "ingest:recent-form": "ts-node --project tsconfig.scripts.json -r tsconfig-paths/register scripts/ingest-recent-form.ts",
    "ingest:market-trends": "ts-node --project tsconfig.scripts.json -r tsconfig-paths/register scripts/ingest-market-trends.ts",
    "ingest:player-props": "ts-node --project tsconfig.scripts.json -r tsconfig-paths/register scripts/ingest-player-props.ts",
    "ingest:team-stats": "ts-node --project tsconfig.scripts.json -r tsconfig-paths/register scripts/ingest-team-stats.ts",
    "reset:tracking": "ts-node --project tsconfig.scripts.json -r tsconfig-paths/register scripts/reset-all-tracking.ts"
  },
  "dependencies": {
