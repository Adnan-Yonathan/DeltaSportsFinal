    "@supabase/supabase-js": "^2.39.0",
    "@tabler/icons-react": "^3.35.0",
    "@types/three": "^0.160.0",
    "ai": "^5.0.93",
    "clsx": "^2.1.1",
    "date-fns": "^3.0.6",
    "next": "^14.2.33",
    "next-themes": "^0.4.6",
    "openai": "^4.20.1",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "react": "^18.2.0",
