{
  "buildCommand": "PLAYWRIGHT_BROWSERS_PATH=0 npx playwright install chromium && npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/chat/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/refresh-projections/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/refresh-projections",
      "schedule": "*/15 * * * *"
    }
  ]
}
