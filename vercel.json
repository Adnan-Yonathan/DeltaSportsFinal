{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "PLAYWRIGHT_BROWSERS_PATH=0 npx playwright install chromium && npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/chat/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/refresh-market-projections/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/refresh-player-projections/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/ingest-whale-trades/route.ts": {
      "maxDuration": 120
    },
    "app/api/cron/ingest-polymarket-wallets/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/ingest-polymarket-wallets-direct/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/compute-polymarket-wallet-rollups/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/ingest-nfl-prop-whales/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/backfill-sharp-feeds/route.ts": {
      "maxDuration": 300
    },
    "app/api/cron/generate-daily-recap/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/refresh-market-projections",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/refresh-player-projections",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/ingest-whale-trades",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/ingest-polymarket-wallets",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/ingest-polymarket-wallets-direct",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/compute-polymarket-wallet-rollups",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/ingest-nfl-prop-whales",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/backfill-sharp-feeds",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/lines/record",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/generate-daily-recap",
      "schedule": "0 11 * * *"
    }
  ]
}
